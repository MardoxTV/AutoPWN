# Copy this file to .env and fill in values.
# .env is gitignored — never commit secrets.

# Static API token for all REST endpoints.
# Leave empty to disable auth (local dev only).
AUTOPWN_API_TOKEN=

# Metasploit MSFRPC password. Must match the -P flag passed to msfrpcd.
MSF_PASSWORD=autopwn_msf_pass

# ── Frontend (copy matching values to frontend/.env.local) ──────────────────
# Must match AUTOPWN_API_TOKEN above so the browser can authenticate.
VITE_API_TOKEN=
